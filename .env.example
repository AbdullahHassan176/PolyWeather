# ── Wallet ────────────────────────────────────────────────────────────────────
# EOA private key that signs orders (never holds funds on-chain)
PRIVATE_KEY=0xyour_private_key_here

# Polymarket Gnosis Safe proxy wallet address (holds USDC, signs with sig_type=2)
# Leave blank if you are using a plain EOA wallet
PROXY_WALLET=

# ── Polymarket CLOB API Credentials ───────────────────────────────────────────
# Accepted under either naming convention; POLYMARKET_API_* takes priority.
# Leave blank to auto-derive from PRIVATE_KEY on first run.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Legacy aliases (used if POLYMARKET_API_* are not set)
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# ── Network ────────────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Winning-position auto-claim (optional) ────────────────────────────────────
# Polymarket has no CLOB redemption endpoint; winning CTF tokens must be claimed
# manually on polymarket.com OR automatically via Parsec's gasless relayer.
# Get a free key at https://parsecapi.com then paste it here.
PARSEC_API_KEY=

# ── Strategy ──────────────────────────────────────────────────────────────────
MIN_EDGE=0.05           # Minimum probability edge to trade (5%)
MAX_TRADE_USDC=50.0     # Max USDC per trade
KELLY_FRACTION=0.25     # Fraction of Kelly criterion to use (0.25 = quarter Kelly)
DRY_RUN=true            # Set to false to enable live trading

# ── Bot timing ────────────────────────────────────────────────────────────────
SCAN_INTERVAL=300       # Seconds between scans (default: 5 minutes)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
